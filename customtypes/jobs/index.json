{
  "format": "custom",
  "id": "jobs",
  "label": "job",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": ""
        }
      },
      "company": {
        "type": "Text",
        "config": {
          "label": "Company",
          "placeholder": ""
        }
      },
      "location": {
        "type": "Text",
        "config": {
          "label": "Location",
          "placeholder": ""
        }
      },
      "contract_type": {
        "type": "Select",
        "config": {
          "label": " Contract Type",
          "placeholder": "",
          "options": ["CDD", "CDI", "Freelance", "Stage", "Alternance"]
        }
      },
      "salary": {
        "type": "Text",
        "config": {
          "label": "Salary",
          "placeholder": ""
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags",
          "repeat": true,
          "fields": {
            "tag": {
              "type": "Text",
              "config": {
                "label": "Tag",
                "placeholder": ""
              }
            }
          }
        }
      },
      "short_description": {
        "type": "Text",
        "config": {
          "label": "Short Description",
          "placeholder": ""
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl"
        }
      },
      "published_date": {
        "type": "Date",
        "config": {
          "label": "Published Date",
          "placeholder": ""
        }
      }
    }
  }
}
